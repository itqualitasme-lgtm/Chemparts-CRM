generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  STAFF
  CUSTOMER
  VENDOR
}

enum UserStatus {
  PENDING
  ACTIVE
  DISABLED
}

model Profile {
  id         String     @id @db.Uuid // = auth.users.id
  email      String     @unique
  fullName   String
  phone      String?
  role       Role
  status     UserStatus @default(ACTIVE)
  customer   Customer?  @relation(fields: [customerId], references: [id])
  customerId String?
  vendor     Vendor?    @relation(fields: [vendorId], references: [id])
  vendorId   String?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
}

model Customer {
  id          String    @id @default(cuid())
  companyName String
  country     String // ISO 3166-1 alpha-2
  city        String?
  address     String?
  trn         String? // VAT/TRN number
  industry    String?
  source      String    @default("SELF") // SELF | STAFF
  notes       String?
  profiles    Profile[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Vendor {
  id           String    @id @default(cuid())
  companyName  String
  country      String
  currency     String    @default("USD")
  paymentTerms String?
  bankDetails  String?
  profiles     Profile[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

enum ProductType {
  EQUIPMENT
  SPARE_PART
  CONSUMABLE
}

model Brand {
  id              String    @id @default(cuid())
  name            String    @unique
  slug            String    @unique @default("")
  logo            String? // Storage URL or imported filename
  website         String?
  countryOfOrigin String?
  focus           String? // specialization, e.g. "Petroleum testing"
  partnerSince    String? // e.g. "2008" or "IN-HOUSE"
  defaultCurrency String    @default("AED")
  description     String?
  featured        Boolean   @default(false)
  products        Product[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model Category {
  id       String     @id @default(cuid())
  name     String
  slug     String     @unique
  type     ProductType
  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  parentId String?
  children Category[] @relation("CategoryTree")
  products Product[]
}

model Product {
  id         String      @id @default(cuid())
  slug       String      @unique
  name       String
  type       ProductType @default(EQUIPMENT)
  brand      Brand       @relation(fields: [brandId], references: [id])
  brandId    String
  category   Category?   @relation(fields: [categoryId], references: [id])
  categoryId String?
  featured   Boolean     @default(false)
  active     Boolean     @default(true)
  image      String?
  images     String[]
  desc       String
  overview   String?
  industries String[]
  testTypes  String[]
  standards  String[]
  specs      Json? // extra arbitrary spec rows beyond the columns below
  // structured spec fields shown on the product page (from the website)
  productType String? // "Petroleum Tester", "Analytical Instrument"
  sample      String? // sample compatibility
  output      String? // output / measurement
  // partnership / warranty / service strip (per-product, were hardcoded on the old site)
  partnerStatus String?  @default("Direct partner") // Authorized: <this>
  warranty      String?  @default("Manufacturer")
  service       String?  @default("In-region")
  modelNo    String?
  hsCode     String?
  unit       String      @default("pc")
  datasheetUrl String? // uploaded specification PDF (Storage)
  // pricing (spares/consumables; equipment stays enquiry-only)
  listPrice  Decimal?    @db.Decimal(12, 2)
  costPrice  Decimal?    @db.Decimal(12, 2)
  currency   String      @default("AED")
  priceUpdatedAt DateTime?
  // stock / inventory
  lotNumber   String?
  stockStatus StockStatus @default(IN_STOCK)
  stockTracked Boolean    @default(false)
  // BOM: this equipment's spare parts, and (reverse) the equipment this spare belongs to
  sparesForThis     EquipmentSpare[] @relation("EquipmentToSpare")
  usedInEquipment   EquipmentSpare[] @relation("SpareToEquipment")
  priceHistory      PriceHistory[]
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
}

enum StockStatus {
  IN_STOCK
  OUT_OF_STOCK
  ON_ORDER
}

enum SpareRequirement {
  REQUIRED
  OPTIONAL
}

// Bill-of-materials link between an equipment product and a spare-part product.
model EquipmentSpare {
  id           String           @id @default(cuid())
  equipment    Product          @relation("EquipmentToSpare", fields: [equipmentId], references: [id], onDelete: Cascade)
  equipmentId  String
  sparePart    Product          @relation("SpareToEquipment", fields: [sparePartId], references: [id], onDelete: Cascade)
  sparePartId  String
  requirement  SpareRequirement @default(OPTIONAL)
  defaultQty   Int              @default(1)
  bundledFree  Boolean          @default(false) // zero-cost when bought with the equipment
  notes        String?
  createdAt    DateTime         @default(now())

  @@unique([equipmentId, sparePartId])
}

model PriceHistory {
  id        String   @id @default(cuid())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String
  oldPrice  Decimal? @db.Decimal(12, 2)
  newPrice  Decimal? @db.Decimal(12, 2)
  currency  String   @default("AED")
  changedById String?
  changedAt DateTime @default(now())
}

model Setting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}

model EmailLog {
  id        String   @id @default(cuid())
  to        String
  subject   String
  template  String
  status    String   @default("SENT") // SENT | FAILED
  error     String?
  createdAt DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?
  action    String
  entity    String
  entityId  String?
  detail    Json?
  createdAt DateTime @default(now())
}
