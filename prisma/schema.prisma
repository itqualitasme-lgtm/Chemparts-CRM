generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  STAFF
  CUSTOMER
  VENDOR
}

enum UserStatus {
  PENDING
  ACTIVE
  DISABLED
}

model Profile {
  id         String     @id @db.Uuid // = auth.users.id
  email      String     @unique
  fullName   String
  phone      String?
  role       Role
  status     UserStatus @default(ACTIVE)
  customer   Customer?  @relation(fields: [customerId], references: [id])
  customerId String?
  vendor     Vendor?    @relation(fields: [vendorId], references: [id])
  vendorId   String?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
}

model Customer {
  id          String    @id @default(cuid())
  companyName String
  country     String // ISO 3166-1 alpha-2
  city        String?
  address     String?
  trn         String? // VAT / TRN number
  tradeLicense String? // trade licence number
  industry    String?
  paymentTerms String? // e.g. "30 days net", "Advance", "50% advance"
  creditLimit Decimal?  @db.Decimal(12, 2)
  currency    String    @default("AED")
  phone       String?
  email       String?
  website     String?
  source      String    @default("SELF") // SELF | STAFF
  notes       String?
  profiles    Profile[]
  contacts    ContactPerson[]
  documents   CustomerDocument[]
  priceRequests PriceRequest[]
  enquiries   Enquiry[]
  quotations  Quotation[]
  orders      Order[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// A named contact at a customer company (many per customer).
model ContactPerson {
  id          String   @id @default(cuid())
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  customerId  String
  name        String
  designation String? // job title / role, e.g. "Lab Manager", "Procurement"
  email       String?
  phone       String?
  isPrimary   Boolean  @default(false)
  createdAt   DateTime @default(now())
}

// An uploaded document for a customer (trade licence, VAT certificate, etc.).
model CustomerDocument {
  id         String   @id @default(cuid())
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  customerId String
  label      String // "Trade License", "VAT Certificate", "Agreement", …
  url        String // Supabase Storage public URL
  createdAt  DateTime @default(now())
}

model Vendor {
  id           String    @id @default(cuid())
  companyName  String
  country      String
  currency     String    @default("USD")
  paymentTerms String?
  bankDetails  String?
  profiles     Profile[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

enum ProductType {
  EQUIPMENT
  SPARE_PART
  CONSUMABLE
}

model Brand {
  id              String    @id @default(cuid())
  name            String    @unique
  slug            String    @unique @default("")
  logo            String? // Storage URL or imported filename
  website         String?
  email           String?
  countryOfOrigin String?
  focus           String? // specialization, e.g. "Petroleum testing"
  partnerSince    String? // e.g. "2008" or "IN-HOUSE"
  defaultCurrency String    @default("AED")
  description     String?
  featured        Boolean   @default(false)
  sortOrder       Int       @default(0)
  products        Product[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model Category {
  id        String      @id @default(cuid())
  name      String
  slug      String      @unique
  type      ProductType
  image     String?
  sortOrder Int         @default(0)
  parent    Category?   @relation("CategoryTree", fields: [parentId], references: [id])
  parentId  String?
  children  Category[]  @relation("CategoryTree")
  products  Product[]
}

enum SaleMode {
  CART_ENABLED
  QUOTE_ONLY
}

enum PriceMode {
  LISTED // confirmed price shown, orderable
  INDICATIVE // price shown but "confirm current price"
  ON_REQUEST // no public price; customer requests it
}

model Product {
  id         String      @id @default(cuid())
  slug       String      @unique
  name       String
  type       ProductType @default(EQUIPMENT)
  brand      Brand       @relation(fields: [brandId], references: [id])
  brandId    String
  category   Category?   @relation(fields: [categoryId], references: [id])
  categoryId String?
  featured   Boolean     @default(false)
  active     Boolean     @default(true)
  image      String?
  images     String[]
  desc       String
  overview   String?
  industries String[]
  testTypes  String[]
  standards  String[]
  tags       String[] // staff hashtags — power search + recent-by-tag discovery
  specs      Json? // extra arbitrary spec rows beyond the columns below
  // structured spec fields shown on the product page (from the website)
  productType String? // "Petroleum Tester", "Analytical Instrument"
  sample      String? // sample compatibility
  output      String? // output / measurement
  // partnership / warranty / service strip (per-product, were hardcoded on the old site)
  partnerStatus String?  @default("Direct partner") // Authorized: <this>
  warranty      String?  @default("Manufacturer")
  service       String?  @default("In-region")
  modelNo    String?
  hsCode     String?
  unit       String      @default("pc")
  datasheetUrl String? // uploaded specification PDF (Storage)
  // pricing (spares/consumables; equipment stays enquiry-only)
  listPrice  Decimal?    @db.Decimal(12, 2)
  costPrice  Decimal?    @db.Decimal(12, 2)
  currency   String      @default("AED")
  priceUpdatedAt DateTime?
  // commerce mode: whether this product can be added to cart or is quote-only
  saleMode    SaleMode   @default(QUOTE_ONLY)
  // price display: staff-controlled; effective state also considers freshness (30d)
  priceMode   PriceMode  @default(ON_REQUEST)
  minOrderQty Int        @default(1)
  sortOrder   Int        @default(0)
  priceRequests PriceRequest[]
  cartItems     CartItem[]
  enquiryItems  EnquiryItem[]
  quotationItems QuotationItem[]
  orderItems    OrderItem[]
  // stock / inventory
  lotNumber   String?
  stockStatus StockStatus @default(IN_STOCK)
  stockTracked Boolean    @default(false)
  // BOM: this equipment's spare parts, and (reverse) the equipment this spare belongs to
  sparesForThis     EquipmentSpare[] @relation("EquipmentToSpare")
  usedInEquipment   EquipmentSpare[] @relation("SpareToEquipment")
  priceHistory      PriceHistory[]
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
}

enum StockStatus {
  IN_STOCK
  OUT_OF_STOCK
  ON_ORDER
}

enum SpareRequirement {
  REQUIRED
  OPTIONAL
}

// Bill-of-materials link between an equipment product and a spare-part product.
model EquipmentSpare {
  id           String           @id @default(cuid())
  equipment    Product          @relation("EquipmentToSpare", fields: [equipmentId], references: [id], onDelete: Cascade)
  equipmentId  String
  sparePart    Product          @relation("SpareToEquipment", fields: [sparePartId], references: [id], onDelete: Cascade)
  sparePartId  String
  requirement  SpareRequirement @default(OPTIONAL)
  defaultQty   Int              @default(1)
  bundledFree  Boolean          @default(false) // zero-cost when bought with the equipment
  notes        String?
  createdAt    DateTime         @default(now())

  @@unique([equipmentId, sparePartId])
}

model PriceHistory {
  id        String   @id @default(cuid())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String
  oldPrice  Decimal? @db.Decimal(12, 2)
  newPrice  Decimal? @db.Decimal(12, 2)
  currency  String   @default("AED")
  changedById String?
  changedAt DateTime @default(now())
}

// ---- Price verification / update-on-request ----
enum PriceRequestStatus {
  OPEN
  QUOTED
  CLOSED
}

model PriceRequest {
  id                  String             @id @default(cuid())
  product             Product            @relation(fields: [productId], references: [id])
  productId           String
  customer            Customer?          @relation(fields: [customerId], references: [id])
  customerId          String?
  requestedByProfile  String? // profile id (null for guest)
  guestName           String?
  guestEmail          String?
  qty                 Int                @default(1)
  message             String?
  status              PriceRequestStatus @default(OPEN)
  quotedPrice         Decimal?           @db.Decimal(12, 2)
  quotedCurrency      String?
  validUntil          DateTime?
  respondedByProfile  String?
  respondedAt         DateTime?
  createdAt           DateTime           @default(now())
}

// ---- Shopping cart (server-persisted, guest-friendly) ----
model Cart {
  id         String     @id @default(cuid())
  customerId String? // resolved on login
  profileId  String? // who is building it
  token      String?    @unique // anonymous cart cookie token for guests
  items      CartItem[]
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
}

model CartItem {
  id                String   @id @default(cuid())
  cart              Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  cartId            String
  product           Product  @relation(fields: [productId], references: [id])
  productId         String
  qty               Int      @default(1)
  quoteOnly         Boolean  @default(false) // priced vs price-on-request at add time
  unitPriceSnapshot Decimal? @db.Decimal(12, 2)
  createdAt         DateTime @default(now())

  @@unique([cartId, productId])
}

// ---- Enquiry (from the website cart OR created by staff for any channel) ----
enum EnquiryStatus {
  NEW
  UNDER_REVIEW
  QUOTED
  WON
  LOST
}

// How the enquiry reached us — we get them many ways.
enum EnquiryType {
  WEBSITE
  PHONE
  EMAIL
  WHATSAPP
  WALK_IN
  REFERRAL
  EXHIBITION
  TENDER
  OTHER
}

model Enquiry {
  id           String        @id @default(cuid())
  enquiryNo    String        @unique
  type         EnquiryType   @default(WEBSITE)
  customer     Customer?     @relation(fields: [customerId], references: [id])
  customerId   String?
  contactName  String? // person who enquired (may differ from customer's primary)
  createdByProfile String?
  guestName    String?
  guestEmail   String?
  guestCompany String?
  guestPhone   String?
  message      String?
  status       EnquiryStatus @default(NEW)
  items        EnquiryItem[]
  quotations   Quotation[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model EnquiryItem {
  id             String   @id @default(cuid())
  enquiry        Enquiry  @relation(fields: [enquiryId], references: [id], onDelete: Cascade)
  enquiryId      String
  product        Product  @relation(fields: [productId], references: [id])
  productId      String
  productName    String // snapshot
  qty            Int      @default(1)
  priceRequested Boolean  @default(false) // was this a price-on-request line
  note           String?
}

// ---- Quotation (priced offer, usually created from an enquiry) ----
enum QuotationStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
}

model Quotation {
  id               String          @id @default(cuid())
  quotationNo      String          @unique
  enquiry          Enquiry?        @relation(fields: [enquiryId], references: [id])
  enquiryId        String?
  customer         Customer?       @relation(fields: [customerId], references: [id])
  customerId       String?
  createdByProfile String?
  status           QuotationStatus @default(DRAFT)
  currency         String          @default("AED")
  vatPercent       Decimal         @default(5) @db.Decimal(5, 2)
  validUntil       DateTime?
  notes            String? // customer-facing notes
  terms            String? // payment / delivery terms
  items            QuotationItem[]
  order            Order?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
}

model QuotationItem {
  id          String    @id @default(cuid())
  quotation   Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  quotationId String
  product     Product?  @relation(fields: [productId], references: [id])
  productId   String?
  productName String // snapshot
  qty         Int       @default(1)
  unitPrice   Decimal   @default(0) @db.Decimal(12, 2)
  note        String?
  sortOrder   Int       @default(0)
}

// ---- Order (a confirmed purchase; carries invoice/warranty/PO documents) ----
enum OrderStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  DELIVERED
  CLOSED
  CANCELLED
}

enum OrderDocKind {
  INVOICE
  WARRANTY
  PURCHASE_ORDER
  DELIVERY_NOTE
  OTHER
}

model Order {
  id               String          @id @default(cuid())
  orderNo          String          @unique
  customer         Customer?       @relation(fields: [customerId], references: [id])
  customerId       String?
  quotation        Quotation?      @relation(fields: [quotationId], references: [id])
  quotationId      String?         @unique
  createdByProfile String?
  status           OrderStatus     @default(PENDING)
  currency         String          @default("AED")
  vatPercent       Decimal         @default(5) @db.Decimal(5, 2)
  notes            String?
  items            OrderItem[]
  documents        OrderDocument[]
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
}

model OrderItem {
  id          String   @id @default(cuid())
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId     String
  product     Product? @relation(fields: [productId], references: [id])
  productId   String?
  productName String // snapshot
  qty         Int      @default(1)
  unitPrice   Decimal  @default(0) @db.Decimal(12, 2)
  sortOrder   Int      @default(0)
}

model OrderDocument {
  id        String       @id @default(cuid())
  order     Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId   String
  kind      OrderDocKind @default(OTHER)
  label     String
  url       String // Supabase Storage public URL
  createdAt DateTime     @default(now())
}

model Setting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}

model EmailLog {
  id        String   @id @default(cuid())
  to        String
  subject   String
  template  String
  status    String   @default("SENT") // SENT | FAILED
  error     String?
  createdAt DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?
  action    String
  entity    String
  entityId  String?
  detail    Json?
  createdAt DateTime @default(now())
}
